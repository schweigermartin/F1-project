# Copy this file to .env (gitignored) and adjust for your own AWS identity.
# These are the values used by Martin during local CDK runs in account 128663321407.

# AWS CLI profile name to use for all CDK commands and local AWS SDK calls.
# Create the profile with: aws configure --profile <name>
AWS_PROFILE=private

# Region all stacks deploy to. Bedrock-Claude availability check needed before Phase 4.
AWS_REGION=eu-central-1

# CDK uses these to pick the deployment target. Should match the AWS_PROFILE's account.
CDK_DEFAULT_ACCOUNT=128663321407
CDK_DEFAULT_REGION=eu-central-1
