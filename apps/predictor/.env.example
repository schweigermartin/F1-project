# Copy to .env.local for local dev (gitignored). Set the same var in Vercel
# (Preview + Production separately — Constitution VII).

# Public HTTPS endpoint of the F1-Inference predictions Read-API (the
# PredictionsApiUrl CfnOutput of the deployed F1-Inference stack). Exposed to
# the browser, so no secrets here. CORS on the Function URL must list this
# app's origin.
NEXT_PUBLIC_PREDICTIONS_API_URL=https://<id>.lambda-url.eu-central-1.on.aws/
