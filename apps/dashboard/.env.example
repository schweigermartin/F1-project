# Copy to .env.local for local dev (gitignored). Set the same vars in Vercel
# (Preview + Production separately — Constitution VII).

# Public wss:// endpoint of the F1-Realtime WebSocket API (CfnOutput of the
# deployed stack, /live stage). Exposed to the browser, so no secrets here.
NEXT_PUBLIC_WS_URL=wss://<api-id>.execute-api.eu-central-1.amazonaws.com/live

# HMAC secret for minting $connect tokens. MUST match the SSM SecureString
# /f1/ws-token-secret that the authorizer reads. Server-side only — never
# prefixed NEXT_PUBLIC_, never shipped to the browser.
WS_TOKEN_SECRET=
